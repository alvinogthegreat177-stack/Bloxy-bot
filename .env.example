# ==========================================================================
# Biney Bot AI - Environment Variables Configuration Template
# Duplicate this file to '.env' and fill in your actual private credentials.
# ==========================================================================

# Server Deployment Settings
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Security Configuration
SECRET_KEY=your_super_secret_session_and_jwt_signing_key_here

# AI Model Provider Credentials (Optional / For future backend connection)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configurations (If switching from local .json files later)
DATABASE_URL=sqlite:///./biney_bot.db
